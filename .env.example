# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase
# (Settings → API no painel). Passo a passo completo em supabase/schema.sql.
#
# Sem estes valores o site funciona em "modo demonstração": os comentários e
# contas ficam salvos só no navegador (localStorage), sem banco de verdade.

# Públicas — podem ir pro cliente (prefixo PUBLIC_ é exposto no build).
PUBLIC_SUPABASE_URL=""
PUBLIC_SUPABASE_ANON_KEY=""

# SECRETA — só no servidor. NUNCA use o prefixo PUBLIC_ aqui.
# Opcional: habilita "redefinir senha" (suporte) e a criação de contas via
# Admin API (permitindo desligar o signup público no Supabase).
# Settings → API Keys → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=""
