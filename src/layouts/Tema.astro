---
import Base from './Base.astro';
import Quiz from '../components/Quiz.jsx';
import Comentarios from '../components/Comentarios.jsx';
import HelpTip from '../components/HelpTip.astro';
import Recursos from '../components/Recursos.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  subject: string;
  relevance: string;
  quickSummary?: string;
  resources?: any;
  questions: any[];
  active: 'enem' | 'escolar' | 'ds';
  breadcrumb: Crumb[];
  slug: string;
}
const { title, subject, relevance, quickSummary, resources, questions, active, breadcrumb, slug } = Astro.props;
---

<Base title={title} active={active} description={relevance}>
  <nav class="font-mono text-xs text-ink-soft mb-4 flex flex-wrap gap-x-1 gap-y-1">
    {breadcrumb.map((b, i) => (
      <Fragment>
        {i > 0 && <span aria-hidden="true">/</span>}
        {b.href ? (
          <a href={b.href} class="hover:text-ink underline underline-offset-2">{b.label}</a>
        ) : (
          <span class="text-ink">{b.label}</span>
        )}
      </Fragment>
    ))}
  </nav>

  <p class="font-mono text-xs uppercase tracking-widest mb-2" style={`color: var(--color-${active})`}>
    {subject}
  </p>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-6 leading-tight">
    {title}
  </h1>

  {quickSummary && (
    <section class="mb-6 rounded-lg p-4" style={`background-color: var(--color-${active}-soft);`}>
      <p class="font-mono text-[11px] uppercase tracking-wide mb-1.5" style={`color: var(--color-${active})`}>
        ⚡ Resumo Rápido
      </p>
      <p class="font-body text-sm text-ink leading-relaxed">{quickSummary}</p>
    </section>
  )}

  <section class="mb-10 border-l-4 pl-5" style={`border-color: var(--color-${active})`}>
    <p class="font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-2">
      Visão Geral e Relevância
    </p>
    <p class="font-body text-ink leading-relaxed">{relevance}</p>
  </section>

  <article class="prose prose-tema max-w-none">
    <slot />
  </article>

  <Recursos resources={resources} accent={active} />

  <div class="flex items-center gap-2 mt-10 mb-1 not-prose">
    <HelpTip title="Como funciona o Teste de Fogo">
      Cada questão tem seu próprio botão de corrigir. Responda e corrija uma de cada vez — errou?
      A explicação aparece na hora, embaixo da própria questão.
    </HelpTip>
  </div>

  <Quiz questions={questions} accent={active} client:visible />

  <div class="flex items-center gap-2 mt-10 mb-1 not-prose">
    <HelpTip title="Como funcionam os comentários">
      Qualquer pessoa pode ler os comentários. Pra escrever, crie uma conta com e-mail e um nome
      de usuário (único, sem repetir). Você pode apagar o que você mesmo escreveu; os ADMs podem
      apagar qualquer comentário pra manter o espaço saudável.
    </HelpTip>
  </div>

  <Comentarios slug={slug} accent={active} client:visible />
</Base>
