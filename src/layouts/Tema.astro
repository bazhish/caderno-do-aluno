---
import Base from './Base.astro';
import Quiz from '../components/Quiz.jsx';
import Comentarios from '../components/Comentarios.jsx';
import HelpTip from '../components/HelpTip.astro';
import Recursos from '../components/Recursos.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  subject: string;
  relevance: string;
  quickSummary?: string;
  resources?: any;
  questions: any[];
  active: 'enem' | 'escolar' | 'ds';
  breadcrumb: Crumb[];
  slug: string;
  // Aulas do banco chegam já renderizadas (markdown → HTML); aulas .mdx usam o <slot />.
  bodyHtml?: string;
  atividades?: { titulo: string; roteiroHtml: string }[];
}
const {
  title,
  subject,
  relevance,
  quickSummary,
  resources,
  questions,
  active,
  breadcrumb,
  slug,
  bodyHtml,
  atividades = [],
} = Astro.props;

// Curso técnico usa "Pause e Responda": 1 questão sorteada por aula.
// ENEM e Regular usam o "Teste de Fogo" com 5.
const quizTitulo = active === 'ds' ? 'Pause e Responda' : 'Teste de Fogo';
const quizSorteio = active === 'ds' ? 1 : 5;
---

<Base title={title} active={active} description={relevance}>
  <nav class="font-mono text-xs text-ink-soft mb-4 flex flex-wrap gap-x-1 gap-y-1">
    {breadcrumb.map((b, i) => (
      <Fragment>
        {i > 0 && <span aria-hidden="true">/</span>}
        {b.href ? (
          <a href={b.href} class="hover:text-ink underline underline-offset-2">{b.label}</a>
        ) : (
          <span class="text-ink">{b.label}</span>
        )}
      </Fragment>
    ))}
  </nav>

  <p class="font-mono text-xs uppercase tracking-widest mb-2" style={`color: var(--color-${active})`}>
    {subject}
  </p>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-6 leading-tight">
    {title}
  </h1>

  {quickSummary && (
    <section class="mb-6 rounded-lg p-4" style={`background-color: var(--color-${active}-soft);`}>
      <p class="font-mono text-[11px] uppercase tracking-wide mb-1.5" style={`color: var(--color-${active})`}>
        ⚡ Resumo Rápido
      </p>
      <p class="font-body text-sm text-ink leading-relaxed">{quickSummary}</p>
    </section>
  )}

  <section class="mb-10 border-l-4 pl-5" style={`border-color: var(--color-${active})`}>
    <p class="font-mono text-[11px] uppercase tracking-wide text-ink-soft mb-2">
      Visão Geral e Relevância
    </p>
    <p class="font-body text-ink leading-relaxed">{relevance}</p>
  </section>

  {bodyHtml ? (
    <article class="prose prose-tema max-w-none" set:html={bodyHtml} />
  ) : (
    <article class="prose prose-tema max-w-none">
      <slot />
    </article>
  )}

  <Recursos resources={resources} accent={active} />

  <div class="flex items-center gap-2 mt-10 mb-1 not-prose">
    <HelpTip title={`Como funciona o ${quizTitulo}`}>
      As questões são sorteadas do banco da aula, só pra você — cada colega recebe um sorteio
      diferente. Corrija uma de cada vez: a explicação aparece na hora. Ao refazer, só vêm
      questões que você ainda não respondeu; quando acabar tudo, dá pra recomeçar do zero.
    </HelpTip>
  </div>

  {/* client:idle: o observer do client:visible não dispara de forma confiável
      nas ilhas mais abaixo da página. */}
  <Quiz
    questions={questions}
    accent={active}
    slug={slug}
    titulo={quizTitulo}
    sortear={quizSorteio}
    client:idle
  />

  {atividades.length > 0 && (
    <section class="not-prose my-10 border-t-2 border-line pt-8">
      <h3 class="font-display text-xl md:text-2xl font-bold text-ink mb-1">Atividades Práticas</h3>
      <p class="font-body text-sm text-ink-soft mb-6">
        Roteiros pra colocar a mão na massa. Sem correção automática e sem gabarito — siga as
        instruções no seu ritmo e tire dúvidas nos comentários.
      </p>
      <div class="space-y-5">
        {atividades.map((a, i) => (
          <div class="rounded-lg border border-paper-dark bg-white/50 p-5">
            <p class="font-mono text-xs font-bold uppercase tracking-wide mb-2" style={`color: var(--color-${active})`}>
              🛠️ Atividade {i + 1} · {a.titulo}
            </p>
            <div class="prose prose-tema max-w-none text-sm" set:html={a.roteiroHtml} />
          </div>
        ))}
      </div>
    </section>
  )}

  <div class="flex items-center gap-2 mt-10 mb-1 not-prose">
    <HelpTip title="Como funcionam os comentários">
      Os comentários atualizam em tempo real e valem pra aula inteira. Você pode apagar o que
      você mesmo escreveu; coordenadores e ADMs moderam o espaço. Palavrões e termos
      preconceituosos são bloqueados automaticamente.
    </HelpTip>
  </div>

  <Comentarios slug={slug} accent={active} client:idle />
</Base>
