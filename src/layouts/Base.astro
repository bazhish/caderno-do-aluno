---
import '../styles/global.css';
import TabNav from '../components/TabNav.astro';
import { u } from '../lib/url';

interface Props {
  title: string;
  active?: 'hub' | 'enem' | 'escolar' | 'ds' | null;
  description?: string;
}
const { title, active = null, description = 'Central de conteúdo da turma' } = Astro.props;
const user = Astro.locals.user;

// A borda da folha segue a cor da aba ativa (o hub usa o mesmo "preto" da aba Início).
const accentByTab: Record<string, string> = {
  hub: 'var(--color-ink)',
  enem: 'var(--color-enem)',
  escolar: 'var(--color-escolar)',
  ds: 'var(--color-ds)',
};
const borderColor = active ? accentByTab[active] : 'var(--color-line)';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Caderno da Turma</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1f2a44" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Caderno da Turma" />
    <meta property="og:title" content={`${title} · Caderno da Turma`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon-512.png" />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Literata:opsz,wght@6..72,400;6..72,500;6..72,600&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Aplica tema/fonte salvos ANTES do primeiro paint (sem flash).
      (function () {
        try {
          var tema = localStorage.getItem('cdt:tema');
          var fonte = localStorage.getItem('cdt:fonte');
          if (tema === 'escuro') document.documentElement.dataset.tema = 'escuro';
          if (fonte === 'moderna') document.documentElement.dataset.fonte = 'moderna';
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="pt-6 sm:pt-8 md:pt-12">
      <div class="px-3 sm:px-4 md:px-10 flex items-center justify-between gap-3 max-w-5xl mx-auto w-full">
        <div class="flex items-center gap-2 sm:gap-3">
          <div class="flex items-center gap-1" role="group" aria-label="Navegação do histórico">
            <button type="button" class="hist-btn" onclick="history.back()" aria-label="Voltar">←</button>
            <button type="button" class="hist-btn" onclick="history.forward()" aria-label="Avançar">→</button>
          </div>
          <a href={u('/')} class="font-display font-bold text-base sm:text-lg md:text-xl text-black no-underline">
            Caderno da Turma<span style="color: var(--color-enem)">.</span>
          </a>
        </div>
        {user ? (
          <details class="user-menu relative" id="menu-usuario">
            <summary class="user-chip" aria-label={`Menu de @${user.username}`}>
              <span class="user-avatar" aria-hidden="true">{user.username.charAt(0).toUpperCase() || '?'}</span>
              <span class="font-mono text-xs text-ink hidden sm:inline">@{user.username}</span>
              {(user.role === 'adm' || user.role === 'coordenador' || user.role === 'professor') && (
                <span class="user-badge">{user.role === 'adm' ? 'ADM' : user.role === 'coordenador' ? 'COORD' : 'PROF'}</span>
              )}
              <span class="text-ink-soft text-[10px]" aria-hidden="true">▾</span>
            </summary>
            <div class="user-panel">
              {(user.role === 'adm' || user.role === 'coordenador') && (
                <a href="/admin" class="user-item">🛠️ <span>Painel de gestão</span></a>
              )}
              <a href="/configuracoes" class="user-item">⚙️ <span>Configurações</span></a>
              <form method="POST" action="/api/auth/logout" class="m-0">
                <button type="submit" class="user-item user-item-sair w-full">↪ <span>Sair da conta</span></button>
              </form>
            </div>
          </details>
        ) : (
          <span class="font-mono text-xs text-ink-soft hidden md:inline">Feito por alunos, para alunos</span>
        )}
      </div>
      <div class="max-w-5xl mx-auto w-full mt-5 sm:mt-6">
        <TabNav active={active} />
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-3 sm:px-4 md:px-10">
      <div
        class="paper-sheet min-h-[60vh] p-4 pl-10 sm:p-6 sm:pl-12 md:p-10 md:pl-16 -mt-[2px]"
        style={`border-color: ${borderColor}; background-color: color-mix(in srgb, var(--color-paper) 92%, white);`}
      >
        <slot />
      </div>
    </main>

    <footer class="max-w-5xl mx-auto w-full px-3 sm:px-4 md:px-10 py-8 sm:py-10 mt-6 flex flex-wrap items-baseline justify-between gap-2">
      <p class="font-mono text-xs text-ink-soft">
        Consulte sempre um professor em caso de dúvidas.
      </p>
      <p class="font-mono text-xs text-ink-soft">Feito por alunos, para alunos 📓</p>
    </footer>

    <style>
      .hist-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        border: 1px solid var(--color-line);
        background: var(--color-paper);
        color: var(--color-ink-soft);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        transition: background-color 0.15s, color 0.15s;
      }
      .hist-btn:hover {
        background: var(--color-paper-dark);
        color: var(--color-ink);
      }

      /* Menu do usuário: um chip arrumado que abre um cartão com as ações. */
      .user-menu > summary {
        list-style: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid var(--color-line);
        background: color-mix(in srgb, var(--color-paper) 88%, white);
        border-radius: 9999px;
        padding: 0.3rem 0.7rem 0.3rem 0.3rem;
        transition: border-color 0.15s, background-color 0.15s;
      }
      .user-menu > summary::-webkit-details-marker { display: none; }
      .user-menu > summary:hover,
      .user-menu[open] > summary {
        border-color: var(--color-ink-soft);
        background: var(--color-paper-dark);
      }
      .user-avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 9999px;
        background: var(--color-ink);
        color: var(--color-paper);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.8rem;
      }
      .user-badge {
        font-family: var(--font-mono);
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.06em;
        border-radius: 9999px;
        padding: 0.1rem 0.45rem;
        background: var(--color-enem-soft);
        color: var(--color-enem);
      }
      .user-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 0.5rem);
        min-width: 12.5rem;
        z-index: 60;
        display: flex;
        flex-direction: column;
        padding: 0.4rem;
        border: 1.5px solid var(--color-line);
        border-radius: 0.6rem;
        background: color-mix(in srgb, var(--color-paper) 92%, white);
        box-shadow: 0 12px 28px rgba(31, 42, 68, 0.14);
      }
      .user-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 0.7rem;
        border-radius: 0.45rem;
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: var(--color-ink);
        text-decoration: none;
        text-align: left;
        background: none;
        border: none;
        cursor: pointer;
      }
      .user-item:hover { background: var(--color-paper-dark); }
      .user-item-sair { color: var(--color-enem); }

      /* Folha estilo fichário: borda na cor da aba ativa e furos perfurados na
         margem esquerda. z-index 5 deixa a folha na frente das abas inativas
         (que ficam "coladas" nas folhas de trás) e atrás da aba ativa (z 30). */
      .paper-sheet {
        position: relative;
        z-index: 5;
        border-width: 2px;
        border-style: solid;
        border-radius: 0 0.6rem 0.6rem 0;
      }
      /* Furos: recuados 12px do topo/base pra nunca encostar na borda;
         background-repeat "space" distribui furos inteiros, sem cortar nenhum.
         Três camadas por furo: miolo na cor do fundo da página (o "vazado"),
         sombra interna no topo e brilho na base — efeito de papel perfurado. */
      .paper-sheet::before {
        content: '';
        position: absolute;
        top: 12px;
        bottom: 12px;
        left: 8px;
        width: 18px;
        pointer-events: none;
        background-image:
          radial-gradient(circle 5px at 9px 20px, var(--color-paper) 99%, transparent 100%),
          radial-gradient(circle 6px at 9px 18.5px, rgba(31, 42, 68, 0.38) 99%, transparent 100%),
          radial-gradient(circle 6px at 9px 21.5px, rgba(255, 255, 255, 0.85) 99%, transparent 100%);
        background-size: 18px 40px;
        background-repeat: no-repeat space;
      }
    </style>

    <script>
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        // fecha o menu do usuário ao clicar fora dele
        const menu = document.getElementById('menu-usuario') as HTMLDetailsElement | null;
        if (menu?.open && !menu.contains(target)) menu.open = false;

        const trigger = target.closest('[data-help-target]');
        if (trigger) {
          const id = trigger.getAttribute('data-help-target');
          const dialog = id ? document.getElementById(id) : null;
          if (dialog instanceof HTMLDialogElement) dialog.showModal();
          return;
        }

        const closeBtn = target.closest('[data-help-close]');
        if (closeBtn) {
          const dialog = closeBtn.closest('dialog');
          if (dialog instanceof HTMLDialogElement) dialog.close();
          return;
        }

        if (target.tagName === 'DIALOG') {
          (target as HTMLDialogElement).close();
        }
      });
    </script>
  </body>
</html>
