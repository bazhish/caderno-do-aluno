---
import '../styles/global.css';
import TabNav from '../components/TabNav.astro';

interface Props {
  title: string;
  active?: 'hub' | 'enem' | 'escolar' | 'ds' | null;
  description?: string;
}
const { title, active = null, description = 'Central de conteúdo da turma' } = Astro.props;

// A borda da folha segue a cor da aba ativa (o hub usa o mesmo "preto" da aba Início).
const accentByTab: Record<string, string> = {
  hub: 'var(--color-ink)',
  enem: 'var(--color-enem)',
  escolar: 'var(--color-escolar)',
  ds: 'var(--color-ds)',
};
const borderColor = active ? accentByTab[active] : 'var(--color-line)';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Caderno do Aluno</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Literata:opsz,wght@6..72,400;6..72,500;6..72,600&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="pt-6 sm:pt-8 md:pt-12">
      <div class="px-3 sm:px-4 md:px-10 flex items-center justify-between gap-3 max-w-5xl mx-auto w-full">
        <div class="flex items-center gap-2 sm:gap-3">
          <div class="flex items-center gap-1" role="group" aria-label="Navegação do histórico">
            <button type="button" class="hist-btn" onclick="history.back()" aria-label="Voltar">←</button>
            <button type="button" class="hist-btn" onclick="history.forward()" aria-label="Avançar">→</button>
          </div>
          <a href="/" class="font-display font-bold text-base sm:text-lg md:text-xl text-black no-underline">
            Caderno do Aluno<span style="color: var(--color-enem)">.</span>
          </a>
        </div>
        <span class="font-mono text-xs text-ink-soft hidden md:inline">Feito por alunos, para alunos</span>
      </div>
      <div class="max-w-5xl mx-auto w-full mt-5 sm:mt-6">
        <TabNav active={active} />
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-3 sm:px-4 md:px-10">
      <div
        class="paper-sheet min-h-[60vh] p-4 pl-10 sm:p-6 sm:pl-12 md:p-10 md:pl-16 -mt-[2px]"
        style={`border-color: ${borderColor}; background-color: color-mix(in srgb, var(--color-paper) 92%, white);`}
      >
        <slot />
      </div>
    </main>

    <footer class="max-w-5xl mx-auto w-full px-3 sm:px-4 md:px-10 py-8 sm:py-10 mt-6">
      <p class="font-mono text-xs text-ink-soft">
        Consulte sempre um professor em caso de dúvidas.
      </p>
    </footer>

    <style>
      .hist-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        border: 1px solid var(--color-line);
        background: var(--color-paper);
        color: var(--color-ink-soft);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        transition: background-color 0.15s, color 0.15s;
      }
      .hist-btn:hover {
        background: var(--color-paper-dark);
        color: var(--color-ink);
      }

      /* Folha estilo fichário: borda na cor da aba ativa e furos perfurados na
         margem esquerda. z-index 5 deixa a folha na frente das abas inativas
         (que ficam "coladas" nas folhas de trás) e atrás da aba ativa (z 30). */
      .paper-sheet {
        position: relative;
        z-index: 5;
        border-width: 2px;
        border-style: solid;
        border-radius: 0 0.6rem 0.6rem 0;
      }
      /* Furos: recuados 12px do topo/base pra nunca encostar na borda;
         background-repeat "space" distribui furos inteiros, sem cortar nenhum.
         Três camadas por furo: miolo na cor do fundo da página (o "vazado"),
         sombra interna no topo e brilho na base — efeito de papel perfurado. */
      .paper-sheet::before {
        content: '';
        position: absolute;
        top: 12px;
        bottom: 12px;
        left: 8px;
        width: 18px;
        pointer-events: none;
        background-image:
          radial-gradient(circle 5px at 9px 20px, var(--color-paper) 99%, transparent 100%),
          radial-gradient(circle 6px at 9px 18.5px, rgba(31, 42, 68, 0.38) 99%, transparent 100%),
          radial-gradient(circle 6px at 9px 21.5px, rgba(255, 255, 255, 0.85) 99%, transparent 100%);
        background-size: 18px 40px;
        background-repeat: no-repeat space;
      }
    </style>

    <script>
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        const trigger = target.closest('[data-help-target]');
        if (trigger) {
          const id = trigger.getAttribute('data-help-target');
          const dialog = id ? document.getElementById(id) : null;
          if (dialog instanceof HTMLDialogElement) dialog.showModal();
          return;
        }

        const closeBtn = target.closest('[data-help-close]');
        if (closeBtn) {
          const dialog = closeBtn.closest('dialog');
          if (dialog instanceof HTMLDialogElement) dialog.close();
          return;
        }

        if (target.tagName === 'DIALOG') {
          (target as HTMLDialogElement).close();
        }
      });
    </script>
  </body>
</html>
