---
import Base from '../layouts/Base.astro';
import HelpTip from '../components/HelpTip.astro';
import { u } from '../lib/url';
import { createSupabaseServer, supabaseConfigured } from '../lib/supabaseServer';
import { salaEmVisao } from '../lib/lessonsRepo';

// O hub começa pela ESCOLHA DA SALA: as seções mudam conforme a sala em visão
// (por padrão, a sala do próprio usuário). O conteúdo continua aberto — trocar
// de sala é livre pra todo mundo; isso só muda o que as listas destacam.
const user = Astro.locals.user;
const salaVisaoId = user ? salaEmVisao(Astro) : null;

interface SalaInfo {
  id: string;
  nome: string;
  cursoSlug: string | null;
}
let salas: SalaInfo[] = [];
if (user && supabaseConfigured) {
  const supabase = createSupabaseServer(Astro);
  const { data } = await supabase
    .from('salas')
    .select('id, nome, ano, cursos(slug)')
    .order('ano')
    .order('nome');
  salas = (data ?? []).map((s) => ({
    id: s.id,
    nome: s.nome,
    cursoSlug: (s.cursos as any)?.slug ?? null,
  }));
}

const salaVisao = salas.find((s) => s.id === salaVisaoId) ?? null;
const minhaArea = salaVisao
  ? salaVisao.cursoSlug === 'ds'
    ? { href: '/ds', label: `material do curso (DS)` }
    : { href: '/escolar', label: `matérias da ${salaVisao.nome}` }
  : null;
const isStaff = user?.role === 'adm' || user?.role === 'coordenador';

const categories = [
  {
    href: '/enem',
    key: 'enem',
    label: 'ENEM',
    color: 'var(--color-enem)',
    soft: 'var(--color-enem-soft)',
    description:
      'Conteúdo focado no que o INEP cobra: teoria direta, pegadinhas mapeadas e questões oficiais para treinar.',
    meta: 'por área e matéria',
  },
  {
    href: '/escolar',
    key: 'escolar',
    label: 'Escolar',
    color: 'var(--color-escolar)',
    soft: 'var(--color-escolar-soft)',
    description:
      'O conteúdo passado em sala de aula, organizado por matéria, bimestre e semana — para quem faltou ou quer revisar.',
    meta: 'por bimestre e semana',
  },
  {
    href: '/ds',
    key: 'ds',
    label: 'DS',
    color: 'var(--color-ds)',
    soft: 'var(--color-ds-soft)',
    description:
      'Material do curso técnico, em linguagem simples, para reforçar o que foi visto em aula.',
    meta: 'por bimestre e semana',
  },
];
---

<Base title="Início" active="hub" description="Painel central de conteúdo de estudo compartilhado pela turma">
  {user && (
    <section class="mb-8 rounded-lg border border-paper-dark bg-white/50 px-5 py-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="font-body text-sm text-ink">
          Olá, <span class="font-mono font-bold">@{user.username}</span>
          {salaVisao && (
            <span class="text-ink-soft">
              {' '}· vendo o material da <b class="text-ink">{salaVisao.nome}</b>
              {user.salaId && salaVisao.id !== user.salaId && ' (não é a sua sala)'}
            </span>
          )}
        </p>
        <span class="flex flex-wrap gap-2">
          {minhaArea && (
            <a
              href={u(minhaArea.href)}
              class="font-display font-bold text-sm px-4 py-2 rounded-md text-white bg-ink hover:opacity-90 transition-opacity no-underline"
            >
              {minhaArea.label} →
            </a>
          )}
          {isStaff && (
            <a
              href="/admin"
              class="font-display font-bold text-sm px-4 py-2 rounded-md border-2 border-ink text-ink hover:bg-ink hover:text-paper transition-colors no-underline"
            >
              🛠️ painel de gestão
            </a>
          )}
        </span>
      </div>

      {salas.length > 0 && (
        <div class="mt-4 pt-4 border-t border-paper-dark">
          <div class="flex items-center gap-2 mb-2">
            <p class="font-mono text-[11px] uppercase tracking-widest text-ink-soft">trocar de sala</p>
            <HelpTip title="Como funciona a troca de sala">
              As seções abaixo mostram o material geral mais o da sala escolhida. Você pode espiar
              o material de qualquer sala (ex: pra conhecer outro curso) — ao clicar na sua, tudo
              volta ao padrão.
            </HelpTip>
          </div>
          <div class="flex flex-wrap gap-2">
            {salas.map((s) => (
              <a
                href={`/api/salas/ver?id=${s.id}`}
                class:list={[
                  'font-mono text-xs rounded-full px-3 py-1.5 no-underline border transition-colors',
                  s.id === salaVisao?.id
                    ? 'bg-ink text-paper border-ink font-bold'
                    : 'border-paper-dark text-ink-soft hover:border-ink-soft hover:text-ink bg-white/40',
                ]}
              >
                {s.nome}
                {user.salaId === s.id && ' ★'}
              </a>
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <section class="mb-12 md:mb-16">
    <div class="flex items-center gap-2 mb-3">
      <p class="font-mono text-xs uppercase tracking-widest text-ink-soft">hub principal</p>
      <HelpTip title="Como usar este hub">
        Este é o painel central: cada card abaixo leva para uma categoria de conteúdo. Use as abas
        no topo para trocar de categoria a qualquer momento, ou os botões de seta para voltar e
        avançar entre páginas já visitadas.
      </HelpTip>
    </div>
    <h1 class="font-display text-3xl md:text-5xl font-bold text-ink leading-tight mb-4 max-w-2xl">
      Tudo o que a turma estuda, num lugar só.
    </h1>
    <p class="font-body text-ink-soft max-w-xl leading-relaxed">
      Escolha uma categoria abaixo. Cada uma organiza o conteúdo de um jeito diferente, mas toda
      aula segue a mesma estrutura: relevância, teoria explicada com calma, resumo para o caderno
      e um teste de 5 questões no final.
    </p>
  </section>

  <section class="grid md:grid-cols-3 gap-5">
    {categories.map((cat) => (
      <a
        href={u(cat.href)}
        class="group block rounded-lg border-2 p-6 transition-transform hover:-translate-y-1"
        style={`border-color: ${cat.color}; background-color: ${cat.soft};`}
      >
        <p class="font-mono text-[11px] uppercase tracking-widest mb-3" style={`color: ${cat.color}`}>
          {cat.meta}
        </p>
        <h2 class="font-display text-2xl font-bold text-ink mb-3">{cat.label}</h2>
        <p class="font-body text-sm text-ink leading-relaxed mb-4">{cat.description}</p>
        <span
          class="font-mono text-xs font-bold uppercase tracking-wide inline-flex items-center gap-1"
          style={`color: ${cat.color}`}
        >
          Entrar
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </span>
      </a>
    ))}
  </section>
</Base>
