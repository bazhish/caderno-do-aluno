---
import Base from '../../../../layouts/Base.astro';
import { buildMateriaBimestreTree, splitSlug, semanaLabel } from '../../../../lib/slug';
import { u } from '../../../../lib/url';
import { listarEntradas } from '../../../../lib/lessonsRepo';

const { materia, bimestre } = Astro.params;
const tree = buildMateriaBimestreTree(await listarEntradas(Astro, 'ds'));
const materiaNode = materia ? tree.get(materia) : undefined;
const bim = bimestre ? materiaNode?.bimestres.get(bimestre) : undefined;
if (!materiaNode || !bim) return Astro.redirect(u('/ds'));
const materiaLabel = materiaNode.label;
const bimestreLabel = bim.label;
const semanas = bim.semanas;
---

<Base title={`${materiaLabel} · ${bimestreLabel}`} active="ds" description={`Semanas de ${materiaLabel}, ${bimestreLabel}`}>
  <nav class="font-mono text-xs text-ink-soft mb-4 flex flex-wrap gap-1">
    <a href={u('/ds')} class="hover:text-ink underline underline-offset-2">DS</a>
    <span>/</span>
    <a href={u(`/ds/${materia}/`)} class="hover:text-ink underline underline-offset-2">{materiaLabel}</a>
    <span>/</span>
    <span class="text-ink">{bimestreLabel}</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-8">{bimestreLabel}</h1>

  <ul class="flex flex-col gap-3 list-none p-0 m-0">
    {semanas.map((s) => (
      <li>
        <a
          href={u(`/ds/${materia}/${bimestre}/${splitSlug(s.id)[2]}/`)}
          class="flex items-center justify-between gap-4 rounded-md border border-paper-dark px-5 py-4 hover:border-ds transition-colors bg-white/50"
        >
          <span class="font-mono text-xs text-ink-soft shrink-0">{semanaLabel(splitSlug(s.id)[2])}</span>
          <span class="font-body text-ink font-medium flex-1 text-right">{s.data.title}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>
