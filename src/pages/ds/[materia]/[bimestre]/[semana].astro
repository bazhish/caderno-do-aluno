---
import Tema from '../../../../layouts/Tema.astro';
import { getCollection, render } from 'astro:content';
import { splitSlug, bimestreLabel as bimLabelFn } from '../../../../lib/slug';
import { u } from '../../../../lib/url';

export async function getStaticPaths() {
  const entries = await getCollection('ds');
  return entries.map((e) => {
    const [materiaSlug, bimestreSlug, semanaSlug] = splitSlug(e.id);
    return {
      params: { materia: materiaSlug, bimestre: bimestreSlug, semana: semanaSlug },
      props: { entry: e },
    };
  });
}

const { materia, bimestre } = Astro.params;
const { entry } = Astro.props;
const { Content } = await render(entry);
const subjectLabel = entry.data.subject;
---

<Tema
  title={entry.data.title}
  subject={subjectLabel}
  relevance={entry.data.relevance}
  quickSummary={entry.data.quickSummary}
  resources={entry.data.resources}
  questions={entry.data.questions}
  active="ds"
  slug={`ds/${entry.id}`}
  breadcrumb={[
    { label: 'DS', href: u('/ds') },
    { label: subjectLabel, href: u(`/ds/${materia}/`) },
    { label: bimLabelFn(bimestre), href: u(`/ds/${materia}/${bimestre}/`) },
    { label: entry.data.title },
  ]}
>
  <Content />
</Tema>
