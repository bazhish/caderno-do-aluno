---
import Tema from '../../../../layouts/Tema.astro';
import { getCollection, render } from 'astro:content';
import { bimestreLabel as bimLabelFn } from '../../../../lib/slug';
import { u } from '../../../../lib/url';
import { buscarAulaDb, listarAtividades, renderMarkdown } from '../../../../lib/lessonsRepo';

const { materia, bimestre, semana } = Astro.params;
const slug = `ds/${materia}/${bimestre}/${semana}`;

const aulaDb = await buscarAulaDb(Astro, slug);

let entry: any = null;
let Content: any = null;
if (!aulaDb) {
  const entries = await getCollection('ds');
  entry = entries.find((e) => e.id === `${materia}/${bimestre}/${semana}`);
  if (!entry) return Astro.redirect(u('/ds'));
  Content = (await render(entry)).Content;
}

const subjectLabel = aulaDb?.materiaNome ?? entry.data.subject;

// Atividades práticas: as do banco (postadas pelo site) + as do frontmatter
// da aula .mdx legada (roteiro em markdown, renderizado aqui).
const atividadesDb = await listarAtividades(Astro, slug);
const atividadesMdx = (entry?.data?.atividades ?? []).map(
  (a: { titulo: string; roteiro: string }) => ({
    titulo: a.titulo,
    roteiroHtml: renderMarkdown(a.roteiro),
  })
);
const atividades = [...atividadesMdx, ...atividadesDb];
---

<Tema
  title={aulaDb?.title ?? entry.data.title}
  subject={subjectLabel}
  relevance={aulaDb?.relevance ?? entry.data.relevance}
  quickSummary={aulaDb?.quickSummary ?? entry.data.quickSummary}
  resources={aulaDb?.resources ?? entry.data.resources}
  questions={aulaDb ? [] : entry.data.questions}
  active="ds"
  slug={slug}
  bodyHtml={aulaDb?.bodyHtml}
  atividades={atividades}
  breadcrumb={[
    { label: 'DS', href: u('/ds') },
    { label: subjectLabel, href: u(`/ds/${materia}/`) },
    { label: bimLabelFn(bimestre ?? ''), href: u(`/ds/${materia}/${bimestre}/`) },
    { label: aulaDb?.title ?? entry.data.title },
  ]}
>
  {Content && <Content />}
</Tema>
