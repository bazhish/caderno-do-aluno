---
import Tema from '../../../layouts/Tema.astro';
import { getCollection, render } from 'astro:content';
import { splitSlug } from '../../../lib/slug';
import { u } from '../../../lib/url';

const { materia, tema } = Astro.params;
const entries = await getCollection('enem');
const entry = entries.find((e) => e.id === `${materia}/${tema}`);
if (!entry) return Astro.redirect(u('/enem'));
const { Content } = await render(entry);
const subjectLabel = entry.data.subject;
---

<Tema
  title={entry.data.title}
  subject={subjectLabel}
  relevance={entry.data.relevance}
  quickSummary={entry.data.quickSummary}
  resources={entry.data.resources}
  questions={entry.data.questions}
  active="enem"
  slug={`enem/${entry.id}`}
  breadcrumb={[
    { label: 'ENEM', href: u('/enem') },
    { label: subjectLabel, href: u(`/enem/${materia}/`) },
    { label: entry.data.title },
  ]}
>
  <Content />
</Tema>
