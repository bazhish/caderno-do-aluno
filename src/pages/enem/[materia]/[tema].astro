---
import Tema from '../../../layouts/Tema.astro';
import { getCollection, render } from 'astro:content';
import { u } from '../../../lib/url';
import { buscarAulaDb, listarAtividades } from '../../../lib/lessonsRepo';

const { materia, tema } = Astro.params;
const slug = `enem/${materia}/${tema}`;

// Banco primeiro (aulas postadas pelo site); .mdx do repositório como legado.
const aulaDb = await buscarAulaDb(Astro, slug);

let entry: any = null;
let Content: any = null;
if (!aulaDb) {
  const entries = await getCollection('enem');
  entry = entries.find((e) => e.id === `${materia}/${tema}`);
  if (!entry) return Astro.redirect(u('/enem'));
  Content = (await render(entry)).Content;
}

const subjectLabel = aulaDb?.materiaNome ?? entry.data.subject;
const atividades = aulaDb ? await listarAtividades(Astro, slug) : [];
---

<Tema
  title={aulaDb?.title ?? entry.data.title}
  subject={subjectLabel}
  relevance={aulaDb?.relevance ?? entry.data.relevance}
  quickSummary={aulaDb?.quickSummary ?? entry.data.quickSummary}
  resources={aulaDb?.resources ?? entry.data.resources}
  questions={aulaDb ? [] : entry.data.questions}
  active="enem"
  slug={slug}
  bodyHtml={aulaDb?.bodyHtml}
  atividades={atividades}
  breadcrumb={[
    { label: 'ENEM', href: u('/enem') },
    { label: subjectLabel, href: u(`/enem/${materia}/`) },
    { label: aulaDb?.title ?? entry.data.title },
  ]}
>
  {Content && <Content />}
</Tema>
