---
import Base from '../../layouts/Base.astro';
import HelpTip from '../../components/HelpTip.astro';
import { buildMateriaBimestreTree } from '../../lib/slug';
import { u } from '../../lib/url';
import { listarEntradas } from '../../lib/lessonsRepo';

const entries = await listarEntradas(Astro, 'escolar');
const tree = buildMateriaBimestreTree(entries);
const materias = [...tree.values()].sort((a, b) => a.label.localeCompare(b.label));
---

<Base title="Escolar" active="escolar" description="Conteúdo de sala de aula, por matéria">
  <div class="flex items-center gap-2 mb-2">
    <p class="font-mono text-xs uppercase tracking-widest" style="color: var(--color-escolar)">escolar</p>
    <HelpTip title="Como funciona a aba Escolar">
      Aqui o conteúdo segue a ordem da sala de aula: matéria, depois bimestre, depois semana. Use
      para revisar uma aula específica ou repor o que você faltou.
    </HelpTip>
  </div>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-3">Matérias</h1>
  <p class="font-body text-ink-soft max-w-lg mb-10 leading-relaxed">
    Conteúdo de sala de aula organizado por matéria, bimestre e semana.
  </p>

  {materias.length === 0 ? (
    <p class="font-body text-ink-soft">Nenhuma matéria publicada ainda.</p>
  ) : (
    <ul class="grid sm:grid-cols-2 gap-4 list-none p-0 m-0">
      {materias.map((m) => (
        <li>
          <a
            href={u(`/escolar/${m.slug}/`)}
            class="block rounded-lg border-2 p-5 hover:-translate-y-0.5 transition-transform"
            style="border-color: var(--color-escolar); background-color: var(--color-escolar-soft);"
          >
            <h2 class="font-display text-xl font-bold text-ink mb-1">{m.label}</h2>
            <p class="font-mono text-xs text-ink-soft">
              {m.bimestres.size} {m.bimestres.size === 1 ? 'bimestre' : 'bimestres'}
            </p>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>
