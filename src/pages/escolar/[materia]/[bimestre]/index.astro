---
import Base from '../../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { buildMateriaBimestreTree, splitSlug, semanaLabel } from '../../../../lib/slug';

export async function getStaticPaths() {
  const entries = await getCollection('escolar');
  const tree = buildMateriaBimestreTree(entries);
  const paths = [];
  for (const [materiaSlug, materia] of tree.entries()) {
    for (const [bimestreSlug, bim] of materia.bimestres.entries()) {
      paths.push({
        params: { materia: materiaSlug, bimestre: bimestreSlug },
        props: { materiaLabel: materia.label, materiaSlug, bimestreLabel: bim.label, semanas: bim.semanas },
      });
    }
  }
  return paths;
}

const { materia, bimestre } = Astro.params;
const { materiaLabel, bimestreLabel, semanas } = Astro.props;
---

<Base title={`${materiaLabel} · ${bimestreLabel}`} active="escolar" description={`Semanas de ${materiaLabel}, ${bimestreLabel}`}>
  <nav class="font-mono text-xs text-ink-soft mb-4 flex flex-wrap gap-1">
    <a href="/escolar" class="hover:text-ink underline underline-offset-2">Escolar</a>
    <span>/</span>
    <a href={`/escolar/${materia}/`} class="hover:text-ink underline underline-offset-2">{materiaLabel}</a>
    <span>/</span>
    <span class="text-ink">{bimestreLabel}</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-8">{bimestreLabel}</h1>

  <ul class="flex flex-col gap-3 list-none p-0 m-0">
    {semanas.map((s) => (
      <li>
        <a
          href={`/escolar/${materia}/${bimestre}/${splitSlug(s.id)[2]}/`}
          class="flex items-center justify-between gap-4 rounded-md border border-paper-dark px-5 py-4 hover:border-escolar transition-colors bg-white/50"
        >
          <span class="font-mono text-xs text-ink-soft shrink-0">{semanaLabel(splitSlug(s.id)[2])}</span>
          <span class="font-body text-ink font-medium flex-1 text-right">{s.data.title}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>
