---
import Base from '../../../layouts/Base.astro';
import { createSupabaseServer } from '../../../lib/supabaseServer';

const user = Astro.locals.user;
if (!user || (user.role !== 'adm' && user.role !== 'coordenador')) {
  return Astro.redirect('/');
}

// Modo edição: /admin/aulas/nova?slug=<slug-da-aula>
const slugEdicao = Astro.url.searchParams.get('slug');
let edicao: any = null;
if (slugEdicao) {
  const supabase = createSupabaseServer(Astro);
  const [{ data: aula }, { data: questoes }, { data: atividades }] = await Promise.all([
    supabase.from('lessons').select('*').eq('slug', slugEdicao).maybeSingle(),
    supabase
      .from('questoes')
      .select('enunciado, alternativas, correct_index, explicacao, fonte')
      .eq('lesson_slug', slugEdicao),
    supabase.from('atividades').select('titulo, roteiro').eq('lesson_slug', slugEdicao).order('ordem'),
  ]);
  if (!aula) return Astro.redirect('/admin');
  edicao = { aula, questoes: questoes ?? [], atividades: atividades ?? [] };
}
const titulo = edicao ? 'Editar aula' : 'Postar aula';
---

<Base title={titulo}>
  <p class="font-mono text-xs uppercase tracking-widest text-ink-soft mb-2">
    painel de gestão · {titulo.toLowerCase()}
  </p>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-3">{titulo}</h1>
  <p class="font-body text-sm text-ink-soft max-w-2xl mb-10 leading-relaxed">
    Preencha por partes — tudo fica salvo de uma vez no final. O conteúdo teórico aceita
    <b>Markdown</b>: <code>## Título de seção</code>, <code>**negrito**</code>, listas com
    <code>-</code>, etc. Capriche: fórmula sempre desmembrada, explicando cada variável.
  </p>

  <form id="form-aula" class="flex flex-col gap-10 max-w-3xl">
    <!-- 1. Endereço da aula -->
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
      <h2 class="font-display text-lg font-bold text-ink mb-4">1 · Onde a aula entra</h2>
      {edicao && (
        <p class="font-mono text-[11px] text-ink-soft mb-4">
          ⚠️ Na edição o endereço fica travado (mudar quebraria comentários e questões da aula).
        </p>
      )}
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="rotulo">Categoria</span>
          <select name="categoria" class="campo" disabled={!!edicao}>
            <option value="enem">ENEM</option>
            <option value="escolar">Escolar (regular)</option>
            <option value="ds">DS (curso técnico)</option>
          </select>
        </label>
        <span></span>
        <label class="block">
          <span class="rotulo">Matéria (nome)</span>
          <input type="text" name="materiaNome" placeholder="ex: Física" required class="campo" />
        </label>
        <label class="block">
          <span class="rotulo">Matéria (slug)</span>
          <input type="text" name="materiaSlug" placeholder="ex: fisica" required class="campo font-mono" disabled={!!edicao} />
        </label>
        <label class="block campo-bimestre">
          <span class="rotulo">Bimestre</span>
          <select name="bimestre" class="campo" disabled={!!edicao}>
            <option value="1">1º</option><option value="2">2º</option>
            <option value="3">3º</option><option value="4">4º</option>
          </select>
        </label>
        <label class="block campo-bimestre">
          <span class="rotulo">Semana</span>
          <input type="number" name="semana" min="1" max="53" value="1" class="campo" disabled={!!edicao} />
        </label>
        <label class="block">
          <span class="rotulo">Título da aula</span>
          <input type="text" name="title" placeholder="ex: Leis de Newton" required class="campo" />
        </label>
        <label class="block">
          <span class="rotulo">Tema (slug)</span>
          <input type="text" name="temaSlug" placeholder="ex: leis-de-newton" required class="campo font-mono" disabled={!!edicao} />
        </label>
      </div>
    </section>

    <!-- 2. Conteúdo -->
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
      <h2 class="font-display text-lg font-bold text-ink mb-4">2 · Conteúdo</h2>
      <label class="block mb-4">
        <span class="rotulo">⚡ Resumo rápido (2–4 linhas, sem enrolação)</span>
        <textarea name="quickSummary" rows="3" class="campo"></textarea>
      </label>
      <label class="block mb-4">
        <span class="rotulo">Visão geral e relevância (por que esse tema importa / com que frequência cai)</span>
        <textarea name="relevance" rows="3" required class="campo"></textarea>
      </label>
      <label class="block">
        <span class="rotulo">Aula teórica completa (Markdown)</span>
        <textarea
          name="bodyMd"
          rows="18"
          required
          class="campo font-mono text-xs"
          placeholder={'## Aula Teórica Completa\n\nTexto explicativo...\n\n## Tópicos-Chave para Revisão\n\n- **Conceito 1** — explicação curta\n- **Conceito 2** — explicação curta'}
        ></textarea>
      </label>
    </section>

    <!-- 3. Recursos de apoio -->
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
      <h2 class="font-display text-lg font-bold text-ink mb-1">3 · Recursos de apoio</h2>
      <p class="font-body text-xs text-ink-soft mb-4">
        Tudo opcional — mas lembre: a aula sintetizada nunca cobre tudo, o material de apoio é
        o que completa. Só aparece no site o que for preenchido.
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        <fieldset class="grupo">
          <legend class="rotulo">🎥 Vídeo aula</legend>
          <input type="url" name="va_link" placeholder="Link" class="campo mb-2" />
          <input type="text" name="va_duracao" placeholder="Duração (ex: 15 min)" class="campo mb-2" />
          <input type="text" name="va_motivo" placeholder="Por que assistir" class="campo" />
        </fieldset>
        <fieldset class="grupo">
          <legend class="rotulo">📚 Curso gratuito</legend>
          <input type="url" name="cg_link" placeholder="Link" class="campo mb-2" />
          <input type="text" name="cg_carga" placeholder="Carga horária (ex: 6h)" class="campo mb-2" />
          <select name="cg_indicado" class="campo">
            <option value="">Indicado para…</option>
            <option value="iniciante">iniciante</option>
            <option value="revisão">revisão</option>
            <option value="avançado">avançado</option>
          </select>
        </fieldset>
        <fieldset class="grupo">
          <legend class="rotulo">📦 Materiais adicionais</legend>
          <input type="text" name="ma_ebook" placeholder="Ebook ou livros" class="campo mb-2" />
          <input type="text" name="ma_exercicios" placeholder="Exercícios" class="campo mb-2" />
          <input type="text" name="ma_prova" placeholder="Prova antiga" class="campo mb-2" />
          <input type="text" name="ma_outro" placeholder="Outro" class="campo mb-2" />
          <select name="ma_nivel" class="campo">
            <option value="">Nível…</option>
            <option value="fácil">fácil</option>
            <option value="médio">médio</option>
            <option value="difícil">difícil</option>
          </select>
        </fieldset>
        <fieldset class="grupo">
          <legend class="rotulo">🔗 Conteúdo similar/complementar</legend>
          <input type="text" name="cc_conteudo" placeholder="Conteúdo" class="campo mb-2" />
          <input type="text" name="cc_como" placeholder="Como ajuda" class="campo" />
        </fieldset>
      </div>
    </section>

    <!-- 4. Questões -->
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
      <h2 class="font-display text-lg font-bold text-ink mb-1">4 · Banco de questões</h2>
      <p class="font-body text-xs text-ink-soft mb-4">
        Quanto mais questões, melhor o sorteio anti-cola (cada aluno recebe questões
        diferentes). No ENEM/Regular o quiz sorteia 5 por vez; no curso (Pause e Responda),
        1 por aula.
      </p>
      {edicao && (
        <label class="flex items-center gap-2 mb-4 font-body text-xs text-ink">
          <input type="checkbox" name="substituirQuestoes" />
          Substituir o banco de questões desta aula (⚠️ zera o histórico de respostas dos alunos)
        </label>
      )}
      <div id="lista-questoes" class="flex flex-col gap-4"></div>
      <button type="button" id="add-questao" class="botao-suave mt-4">+ adicionar questão</button>
    </section>

    <!-- 5. Atividades práticas (curso) -->
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5 secao-atividades">
      <h2 class="font-display text-lg font-bold text-ink mb-1">5 · Atividades práticas</h2>
      <p class="font-body text-xs text-ink-soft mb-4">
        Só pro curso técnico: roteiro em texto livre (aceita Markdown), com instruções claras.
        Sem correção automática, sem gabarito. Aparecem depois do Pause e Responda.
      </p>
      <div id="lista-atividades" class="flex flex-col gap-4"></div>
      <button type="button" id="add-atividade" class="botao-suave mt-4">+ adicionar atividade</button>
    </section>

    <!-- 6. Publicar -->
    <section class="flex flex-wrap items-center gap-4">
      <select name="status" class="campo max-w-40">
        <option value="publicado">Publicar agora</option>
        <option value="rascunho">Salvar como rascunho</option>
      </select>
      <button
        type="submit"
        class="font-display font-bold px-8 py-3 rounded-md text-white bg-ds hover:opacity-90 transition-opacity"
      >
        Salvar aula
      </button>
      <a href="/admin" class="font-mono text-xs text-ink-soft hover:text-ink underline underline-offset-2">cancelar</a>
      <p id="resultado" class="font-body text-sm w-full"></p>
    </section>
  </form>

  <!-- Templates dos blocos dinâmicos -->
  <template id="tpl-questao">
    <div class="grupo questao">
      <div class="flex items-center justify-between mb-2">
        <span class="rotulo num-questao">Questão</span>
        <button type="button" class="remover font-mono text-[11px] text-ink-soft hover:text-enem underline">remover</button>
      </div>
      <textarea data-campo="enunciado" rows="2" placeholder="Enunciado" class="campo mb-2"></textarea>
      <div class="flex flex-col gap-1.5 mb-2">
        <div class="flex gap-2 items-center"><input type="radio" data-correta /> <input type="text" data-alt placeholder="Alternativa A" class="campo" /></div>
        <div class="flex gap-2 items-center"><input type="radio" data-correta /> <input type="text" data-alt placeholder="Alternativa B" class="campo" /></div>
        <div class="flex gap-2 items-center"><input type="radio" data-correta /> <input type="text" data-alt placeholder="Alternativa C" class="campo" /></div>
        <div class="flex gap-2 items-center"><input type="radio" data-correta /> <input type="text" data-alt placeholder="Alternativa D" class="campo" /></div>
        <div class="flex gap-2 items-center"><input type="radio" data-correta /> <input type="text" data-alt placeholder="Alternativa E" class="campo" /></div>
      </div>
      <p class="font-mono text-[10px] text-ink-soft mb-2">marque a bolinha da alternativa correta</p>
      <textarea data-campo="explicacao" rows="2" placeholder="Explicação da resposta (e a pegadinha, se houver)" class="campo mb-2"></textarea>
      <input type="text" data-campo="fonte" placeholder="Fonte (opcional, ex: ENEM 2022 — questão 136)" class="campo" />
    </div>
  </template>

  <template id="tpl-atividade">
    <div class="grupo atividade">
      <div class="flex items-center justify-between mb-2">
        <span class="rotulo num-atividade">Atividade</span>
        <button type="button" class="remover font-mono text-[11px] text-ink-soft hover:text-enem underline">remover</button>
      </div>
      <input type="text" data-campo="titulo" placeholder="Título (ex: Monte a tela de login no app)" class="campo mb-2" />
      <textarea data-campo="roteiro" rows="6" placeholder={'Roteiro com instruções claras (aceita Markdown):\n1. Abra o projeto...\n2. Crie o componente...'} class="campo font-mono text-xs"></textarea>
    </div>
  </template>

  {edicao && (
    <script type="application/json" id="dados-edicao" set:html={JSON.stringify(edicao)} />
  )}

  <style>
    .rotulo {
      display: block;
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-ink-soft);
      margin-bottom: 0.35rem;
    }
    .campo {
      width: 100%;
      border-radius: 0.375rem;
      border: 1px solid var(--color-paper-dark);
      background: rgb(255 255 255 / 0.8);
      padding: 0.5rem 0.75rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      color: var(--color-ink);
    }
    .campo:focus { outline: none; border-color: var(--color-ink-soft); }
    .campo:disabled { opacity: 0.55; cursor: not-allowed; }
    .grupo {
      border: 1px solid var(--color-paper-dark);
      border-radius: 0.5rem;
      padding: 1rem;
      background: rgb(255 255 255 / 0.35);
    }
    .botao-suave {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      padding: 0.5rem 1rem;
      border-radius: 0.375rem;
      border: 2px dashed var(--color-paper-dark);
      color: var(--color-ink-soft);
    }
    .botao-suave:hover { color: var(--color-ink); border-color: var(--color-ink-soft); }
  </style>

  <script>
    const form = document.getElementById('form-aula') as HTMLFormElement;
    const resultado = document.getElementById('resultado')!;
    const listaQuestoes = document.getElementById('lista-questoes')!;
    const listaAtividades = document.getElementById('lista-atividades')!;
    const tplQuestao = document.getElementById('tpl-questao') as HTMLTemplateElement;
    const tplAtividade = document.getElementById('tpl-atividade') as HTMLTemplateElement;
    const dadosEdicao = document.getElementById('dados-edicao');
    const edicao = dadosEdicao ? JSON.parse(dadosEdicao.textContent ?? 'null') : null;

    const slugify = (t: string) =>
      t.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase()
        .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

    const campo = (name: string) => form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

    // slugs automáticos a partir dos nomes (editáveis depois)
    campo('materiaNome')?.addEventListener('input', () => {
      if (!(campo('materiaSlug') as HTMLInputElement).disabled) campo('materiaSlug').value = slugify(campo('materiaNome').value);
    });
    campo('title')?.addEventListener('input', () => {
      if (!(campo('temaSlug') as HTMLInputElement).disabled) campo('temaSlug').value = slugify(campo('title').value);
    });

    // categoria controla bimestre/semana e atividades
    function ajustarCategoria() {
      const cat = campo('categoria').value;
      document.querySelectorAll('.campo-bimestre').forEach((el) => {
        (el as HTMLElement).style.display = cat === 'enem' ? 'none' : '';
      });
      (document.querySelector('.secao-atividades') as HTMLElement).style.display = cat === 'ds' ? '' : 'none';
    }
    campo('categoria').addEventListener('change', ajustarCategoria);

    function renumerar() {
      listaQuestoes.querySelectorAll('.questao').forEach((q, i) => {
        q.querySelector('.num-questao')!.textContent = `Questão ${i + 1}`;
        q.querySelectorAll('[data-correta]').forEach((r) => ((r as HTMLInputElement).name = `correta-${i}`));
      });
      listaAtividades.querySelectorAll('.atividade').forEach((a, i) => {
        a.querySelector('.num-atividade')!.textContent = `Atividade ${i + 1}`;
      });
    }

    function addQuestao(dados?: any) {
      const node = tplQuestao.content.cloneNode(true) as DocumentFragment;
      const bloco = node.querySelector('.questao')!;
      bloco.querySelector('.remover')!.addEventListener('click', () => { bloco.remove(); renumerar(); });
      if (dados) {
        (bloco.querySelector('[data-campo="enunciado"]') as HTMLTextAreaElement).value = dados.enunciado ?? '';
        (bloco.querySelector('[data-campo="explicacao"]') as HTMLTextAreaElement).value = dados.explicacao ?? '';
        (bloco.querySelector('[data-campo="fonte"]') as HTMLInputElement).value = dados.fonte ?? '';
        bloco.querySelectorAll('[data-alt]').forEach((el, i) => ((el as HTMLInputElement).value = dados.alternativas?.[i] ?? ''));
        const radios = bloco.querySelectorAll('[data-correta]');
        if (dados.correct_index >= 0) (radios[dados.correct_index] as HTMLInputElement).checked = true;
      }
      listaQuestoes.appendChild(node);
      renumerar();
    }

    function addAtividade(dados?: any) {
      const node = tplAtividade.content.cloneNode(true) as DocumentFragment;
      const bloco = node.querySelector('.atividade')!;
      bloco.querySelector('.remover')!.addEventListener('click', () => { bloco.remove(); renumerar(); });
      if (dados) {
        (bloco.querySelector('[data-campo="titulo"]') as HTMLInputElement).value = dados.titulo ?? '';
        (bloco.querySelector('[data-campo="roteiro"]') as HTMLTextAreaElement).value = dados.roteiro ?? '';
      }
      listaAtividades.appendChild(node);
      renumerar();
    }

    document.getElementById('add-questao')!.addEventListener('click', () => addQuestao());
    document.getElementById('add-atividade')!.addEventListener('click', () => addAtividade());

    // preencher em modo edição
    if (edicao) {
      const a = edicao.aula;
      campo('categoria').value = a.categoria;
      campo('materiaNome').value = a.materia_nome;
      campo('materiaSlug').value = a.materia_slug;
      if (a.bimestre) campo('bimestre').value = String(a.bimestre);
      if (a.semana) campo('semana').value = String(a.semana);
      campo('title').value = a.title;
      campo('temaSlug').value = a.slug.split('/').pop() ?? '';
      campo('quickSummary').value = a.quick_summary ?? '';
      campo('relevance').value = a.relevance ?? '';
      campo('bodyMd').value = a.body_md ?? '';
      campo('status').value = a.status;
      const r = a.resources ?? {};
      campo('va_link').value = r.videoAula?.link ?? '';
      campo('va_duracao').value = r.videoAula?.duracao ?? '';
      campo('va_motivo').value = r.videoAula?.motivo ?? '';
      campo('cg_link').value = r.cursoGratuito?.link ?? '';
      campo('cg_carga').value = r.cursoGratuito?.cargaHoraria ?? '';
      campo('cg_indicado').value = r.cursoGratuito?.indicadoPara ?? '';
      campo('ma_ebook').value = r.materiaisAdicionais?.ebook ?? '';
      campo('ma_exercicios').value = r.materiaisAdicionais?.exercicios ?? '';
      campo('ma_prova').value = r.materiaisAdicionais?.provaAntiga ?? '';
      campo('ma_outro').value = r.materiaisAdicionais?.outro ?? '';
      campo('ma_nivel').value = r.materiaisAdicionais?.nivel ?? '';
      campo('cc_conteudo').value = r.conteudoComplementar?.conteudo ?? '';
      campo('cc_como').value = r.conteudoComplementar?.comoAjuda ?? '';
      for (const q of edicao.questoes) addQuestao(q);
      for (const at of edicao.atividades) addAtividade(at);
    } else {
      addQuestao(); // já abre com uma questão pra dar o caminho
    }
    ajustarCategoria();

    function montarResources() {
      const v = (n: string) => (campo(n)?.value ?? '').trim();
      const resources: any = {};
      if (v('va_link')) resources.videoAula = { link: v('va_link'), duracao: v('va_duracao') || undefined, motivo: v('va_motivo') || undefined };
      if (v('cg_link')) resources.cursoGratuito = { link: v('cg_link'), cargaHoraria: v('cg_carga') || undefined, indicadoPara: v('cg_indicado') || undefined };
      if (v('ma_ebook') || v('ma_exercicios') || v('ma_prova') || v('ma_outro')) {
        resources.materiaisAdicionais = {
          ebook: v('ma_ebook') || undefined, exercicios: v('ma_exercicios') || undefined,
          provaAntiga: v('ma_prova') || undefined, outro: v('ma_outro') || undefined,
          nivel: v('ma_nivel') || undefined,
        };
      }
      if (v('cc_conteudo')) resources.conteudoComplementar = { conteudo: v('cc_conteudo'), comoAjuda: v('cc_como') || undefined };
      return Object.keys(resources).length ? resources : null;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      resultado.textContent = 'Salvando…';
      resultado.className = 'font-body text-sm w-full text-ink-soft';

      const questoes = [...listaQuestoes.querySelectorAll('.questao')].map((bloco) => {
        const radios = [...bloco.querySelectorAll('[data-correta]')];
        return {
          enunciado: (bloco.querySelector('[data-campo="enunciado"]') as HTMLTextAreaElement).value,
          alternativas: [...bloco.querySelectorAll('[data-alt]')].map((el) => (el as HTMLInputElement).value),
          correta: radios.findIndex((r) => (r as HTMLInputElement).checked),
          explicacao: (bloco.querySelector('[data-campo="explicacao"]') as HTMLTextAreaElement).value,
          fonte: (bloco.querySelector('[data-campo="fonte"]') as HTMLInputElement).value,
        };
      });
      const cat = campo('categoria').value;
      const atividades = cat === 'ds'
        ? [...listaAtividades.querySelectorAll('.atividade')].map((bloco) => ({
            titulo: (bloco.querySelector('[data-campo="titulo"]') as HTMLInputElement).value,
            roteiro: (bloco.querySelector('[data-campo="roteiro"]') as HTMLTextAreaElement).value,
          }))
        : [];

      const payload = {
        modo: edicao ? 'editar' : 'criar',
        slugOriginal: edicao?.aula?.slug,
        categoria: cat,
        materiaNome: campo('materiaNome').value,
        materiaSlug: campo('materiaSlug').value,
        bimestre: campo('bimestre').value,
        semana: campo('semana').value,
        title: campo('title').value,
        temaSlug: campo('temaSlug').value,
        quickSummary: campo('quickSummary').value,
        relevance: campo('relevance').value,
        bodyMd: campo('bodyMd').value,
        resources: montarResources(),
        status: campo('status').value,
        questoes,
        atividades,
        substituirQuestoes: (form.elements.namedItem('substituirQuestoes') as HTMLInputElement | null)?.checked ?? false,
      };

      try {
        const resp = await fetch('/api/aulas/salvar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const corpo = await resp.json();
        if (!resp.ok) throw new Error(corpo.error ?? 'Falha desconhecida');
        resultado.textContent = '✓ Aula salva! Abrindo…';
        resultado.className = 'font-body text-sm w-full text-ds';
        window.location.href = corpo.url;
      } catch (err) {
        resultado.textContent = '✕ ' + (err instanceof Error ? err.message : 'Erro inesperado');
        resultado.className = 'font-body text-sm w-full text-enem';
      }
    });
  </script>
</Base>
