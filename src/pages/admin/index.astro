---
import Base from '../../layouts/Base.astro';
import { createSupabaseServer } from '../../lib/supabaseServer';

const user = Astro.locals.user;
if (!user || (user.role !== 'adm' && user.role !== 'coordenador')) {
  return Astro.redirect('/');
}
const isAdm = user.role === 'adm';

const supabase = createSupabaseServer(Astro);
const [{ data: salas }, { data: cursos }, { data: perfis }, { data: privados }, { data: aulas }, metricasRes] =
  await Promise.all([
    supabase.from('salas').select('id, nome, ano').order('nome'),
    supabase.from('cursos').select('slug, nome').order('nome'),
    supabase
      .from('profiles')
      .select('*') // '*' degrada bem: materia/fundador só existem após o schema-v5
      .order('created_at', { ascending: false })
      .limit(200),
    supabase.from('profiles_privados').select('user_id, nome_completo'),
    supabase
      .from('lessons')
      .select('slug, title, categoria, status, updated_at')
      .order('updated_at', { ascending: false })
      .limit(100),
    supabase.rpc('metricas_admin'),
  ]);

const metricas: Record<string, number> | null = metricasRes.error ? null : metricasRes.data;
const nomePorId = new Map((privados ?? []).map((p) => [p.user_id, p.nome_completo]));
const salaPorId = new Map((salas ?? []).map((s) => [s.id, s.nome]));
const minhaSala = user.salaId ? (salaPorId.get(user.salaId) ?? '—') : null;

const rotulosMetricas: [string, string][] = [
  ['usuarios', 'contas'],
  ['aulas_no_banco', 'aulas postadas'],
  ['questoes', 'questões no banco'],
  ['comentarios', 'comentários'],
  ['respostas_registradas', 'respostas de quiz'],
];
---

<Base title="Gestão">
  <p class="font-mono text-xs uppercase tracking-widest text-ink-soft mb-2">
    painel de gestão · {isAdm ? 'ADM' : `coordenador ${minhaSala ? `· ${minhaSala}` : ''}`}
  </p>
  <h1 class="font-display text-3xl md:text-4xl font-bold text-ink mb-10">Gestão da turma</h1>

  {metricas && (
    <section class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 mb-12">
      {rotulosMetricas.map(([chave, rotulo]) => (
        <div class="rounded-lg border border-paper-dark bg-white/50 px-4 py-3 text-center">
          <p class="font-display text-2xl font-bold text-ink">{metricas[chave] ?? 0}</p>
          <p class="font-mono text-[10px] uppercase tracking-wide text-ink-soft">{rotulo}</p>
        </div>
      ))}
    </section>
  )}

  <section class="mb-12">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
      <h2 class="font-display text-lg font-bold text-ink">
        Aulas postadas pelo site <span class="font-mono text-xs text-ink-soft">({(aulas ?? []).length})</span>
      </h2>
      <span class="flex items-center gap-3">
        <a
          href="https://github.com/bazhish/caderno-da-turma/blob/main/POSTAR_AULA.md"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[11px] text-ink-soft hover:text-ink underline underline-offset-2"
        >modo avançado (GitHub) ↗</a>
        <a
          href="/admin/aulas/nova"
          class="font-display font-bold text-sm px-5 py-2.5 rounded-md text-white bg-ds hover:opacity-90 transition-opacity no-underline"
        >+ Postar aula</a>
      </span>
    </div>
    {(aulas ?? []).length === 0 ? (
      <p class="font-body text-sm text-ink-soft rounded-md border border-paper-dark bg-white/40 px-4 py-5">
        Nenhuma aula postada pelo site ainda — as aulas atuais vêm do repositório (.mdx). Clique
        em "+ Postar aula" pra publicar a primeira pelo formulário.
      </p>
    ) : (
      <ul class="flex flex-col gap-2 list-none p-0 m-0">
        {(aulas ?? []).map((a) => (
          <li class="flex flex-wrap items-center gap-x-3 gap-y-1 rounded-md border border-paper-dark bg-white/50 px-4 py-3">
            <span class:list={[
              'font-mono text-[10px] font-bold uppercase tracking-wide rounded-full px-2 py-0.5',
              a.categoria === 'enem' && 'bg-enem-soft text-enem',
              a.categoria === 'escolar' && 'bg-escolar-soft text-escolar',
              a.categoria === 'ds' && 'bg-ds-soft text-ds',
            ]}>{a.categoria}</span>
            <a href={`/${a.slug}/`} class="font-body text-sm text-ink font-medium hover:underline">{a.title}</a>
            {a.status === 'rascunho' && (
              <span class="font-mono text-[10px] uppercase text-ink-soft border border-paper-dark rounded-full px-2 py-0.5">rascunho</span>
            )}
            <span class="ml-auto flex gap-3">
              <a href={`/admin/aulas/nova?slug=${encodeURIComponent(a.slug)}`} class="font-mono text-[11px] text-ink-soft hover:text-ink underline underline-offset-2">editar</a>
              <button type="button" data-excluir={a.slug} class="font-mono text-[11px] text-ink-soft hover:text-enem underline underline-offset-2">excluir</button>
            </span>
          </li>
        ))}
      </ul>
    )}
    <p id="resultado-aulas" class="font-body text-xs mt-2"></p>
  </section>

  <div class="grid md:grid-cols-2 gap-8 mb-12">
    <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
      <h2 class="font-display text-lg font-bold text-ink mb-1">Registrar conta</h2>
      <p class="font-body text-xs text-ink-soft mb-4 leading-relaxed">
        A senha padrão é gerada no formato <code>nome.sobrenome@ano</code> — anote e entregue
        à pessoa. No primeiro login o sistema obriga a trocar.
      </p>
      <form id="form-usuario" class="flex flex-col gap-3">
        <input
          type="text"
          name="nomeCompleto"
          placeholder="Nome completo (ex: João Silva Santos)"
          required
          class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none focus:border-ink-soft"
        />
        <input
          type="text"
          name="username"
          placeholder="Username (ex: joao.s.3dsa)"
          required
          class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none focus:border-ink-soft"
        />
        {isAdm && (
          <select
            name="papel"
            id="sel-papel"
            class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none"
          >
            <option value="aluno">Aluno</option>
            <option value="professor">Professor</option>
            <option value="coordenador">Coordenador</option>
            <option value="adm">ADM</option>
          </select>
        )}
        {isAdm ? (
          <>
            <select
              name="salaId"
              id="campo-sala"
              class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none"
            >
              <option value="">Escolha a sala…</option>
              {(salas ?? []).map((s) => <option value={s.id}>{s.nome}</option>)}
            </select>
            <input
              type="text"
              name="materia"
              id="campo-materia"
              placeholder="Matéria que leciona (ex: Matemática)"
              style="display: none"
              class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none focus:border-ink-soft"
            />
            <p id="dica-papel" class="font-mono text-[11px] text-ink-soft leading-relaxed">
              Aluno e coordenador entram numa sala. Professor é registrado pela matéria.
              ADM não tem sala nem matéria — tem todas as permissões.
            </p>
          </>
        ) : (
          <p class="font-mono text-[11px] text-ink-soft">Sala: {minhaSala ?? 'sem sala definida'}</p>
        )}
        <button
          type="submit"
          class="font-display font-bold text-sm px-5 py-2.5 rounded-md text-white bg-ds hover:opacity-90 transition-opacity self-start"
        >
          Registrar
        </button>
        <p id="resultado-usuario" class="font-body text-xs leading-relaxed"></p>
      </form>
    </section>

    {isAdm && (
      <section class="rounded-lg border border-paper-dark bg-white/50 p-5">
        <h2 class="font-display text-lg font-bold text-ink mb-1">Criar sala</h2>
        <p class="font-body text-xs text-ink-soft mb-4 leading-relaxed">
          Ex: "3º DS A". Salas de 1º ano não têm curso.
        </p>
        <form id="form-sala" class="flex flex-col gap-3">
          <input
            type="text"
            name="nome"
            placeholder="Nome da sala (ex: 3º DS A)"
            required
            class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none focus:border-ink-soft"
          />
          <select
            name="ano"
            class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none"
          >
            <option value="1">1º ano</option>
            <option value="2">2º ano</option>
            <option value="3">3º ano</option>
          </select>
          <select
            name="cursoSlug"
            class="w-full rounded-md border border-paper-dark bg-white/80 px-3 py-2 font-body text-sm text-ink focus:outline-none"
          >
            <option value="">Sem curso (regular)</option>
            {(cursos ?? []).map((c) => <option value={c.slug}>{c.nome}</option>)}
          </select>
          <button
            type="submit"
            class="font-display font-bold text-sm px-5 py-2.5 rounded-md text-white bg-escolar hover:opacity-90 transition-opacity self-start"
          >
            Criar sala
          </button>
          <p id="resultado-sala" class="font-body text-xs leading-relaxed"></p>
        </form>
      </section>
    )}
  </div>

  <section>
    <h2 class="font-display text-lg font-bold text-ink mb-4">
      Contas registradas <span class="font-mono text-xs text-ink-soft">({(perfis ?? []).length})</span>
    </h2>
    <div class="overflow-x-auto rounded-lg border border-paper-dark bg-white/50">
      <table class="w-full text-left">
        <thead>
          <tr class="font-mono text-[11px] uppercase tracking-wide text-ink-soft border-b border-paper-dark">
            <th class="px-4 py-3">Username</th>
            <th class="px-4 py-3">Nome completo</th>
            <th class="px-4 py-3">Sala / Matéria</th>
            <th class="px-4 py-3">Papel</th>
            <th class="px-4 py-3">Ações</th>
          </tr>
        </thead>
        <tbody class="font-body text-sm text-ink">
          {(perfis ?? []).map((p) => (
            <tr class="border-b border-paper-dark/50 last:border-0">
              <td class="px-4 py-2.5 font-mono text-xs">@{p.username}</td>
              <td class="px-4 py-2.5">{nomePorId.get(p.id) ?? '—'}</td>
              <td class="px-4 py-2.5">
                {p.role === 'professor'
                  ? (p.materia ?? '—')
                  : p.sala_id
                    ? (salaPorId.get(p.sala_id) ?? '—')
                    : '—'}
              </td>
              <td class="px-4 py-2.5">
                <span
                  class:list={[
                    'font-mono text-[10px] font-bold uppercase tracking-wide rounded-full px-2 py-0.5',
                    p.role === 'adm' && 'bg-ink text-paper',
                    p.role === 'coordenador' && 'bg-escolar-soft text-escolar',
                    p.role === 'professor' && 'bg-ds-soft text-ds',
                    p.role === 'aluno' && 'bg-paper-dark/60 text-ink-soft',
                  ]}
                >
                  {p.fundador ? 'adm ★' : p.role}
                </span>
              </td>
              <td class="px-4 py-2.5">
                <span class="flex flex-wrap gap-x-3 gap-y-1">
                  {(isAdm || (p.role === 'aluno' && p.sala_id === user.salaId)) && p.id !== user.id && (
                    <button
                      type="button"
                      data-redefinir={p.username}
                      class="font-mono text-[11px] text-ink-soft hover:text-ink underline underline-offset-2"
                    >redefinir senha</button>
                  )}
                  {isAdm && !p.fundador && p.id !== user.id && (
                    <>
                      <button
                        type="button"
                        data-papel={p.username}
                        data-papel-atual={p.role}
                        class="font-mono text-[11px] text-ink-soft hover:text-ink underline underline-offset-2"
                      >trocar papel</button>
                      <button
                        type="button"
                        data-renomear={p.username}
                        class="font-mono text-[11px] text-ink-soft hover:text-ink underline underline-offset-2"
                      >renomear</button>
                      <button
                        type="button"
                        data-excluir-usuario={p.username}
                        class="font-mono text-[11px] text-ink-soft hover:text-enem underline underline-offset-2"
                      >excluir</button>
                    </>
                  )}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p id="resultado-senha" class="font-body text-xs mt-2"></p>
  </section>

  <script>
    async function enviar(form: HTMLFormElement, url: string, resultado: HTMLElement) {
      const dados = Object.fromEntries(new FormData(form).entries());
      resultado.textContent = 'Enviando…';
      resultado.className = 'font-body text-xs leading-relaxed text-ink-soft';
      try {
        const resp = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dados),
        });
        const corpo = await resp.json();
        if (!resp.ok) throw new Error(corpo.error ?? 'Falha desconhecida');
        return corpo;
      } catch (e) {
        resultado.textContent = '✕ ' + (e instanceof Error ? e.message : 'Erro inesperado');
        resultado.className = 'font-body text-xs leading-relaxed text-enem';
        return null;
      }
    }

    // Papel escolhido controla o campo extra: sala (aluno/coordenador),
    // matéria (professor) ou nenhum (ADM).
    const selPapel = document.getElementById('sel-papel') as HTMLSelectElement | null;
    const campoSala = document.getElementById('campo-sala') as HTMLSelectElement | null;
    const campoMateria = document.getElementById('campo-materia') as HTMLInputElement | null;
    function ajustarCampos() {
      if (!selPapel || !campoSala || !campoMateria) return;
      const papel = selPapel.value;
      campoSala.style.display = papel === 'aluno' || papel === 'coordenador' ? '' : 'none';
      campoMateria.style.display = papel === 'professor' ? '' : 'none';
      if (papel !== 'professor') campoMateria.value = '';
      if (papel === 'professor' || papel === 'adm') campoSala.value = '';
    }
    selPapel?.addEventListener('change', ajustarCampos);
    ajustarCampos();

    const formUsuario = document.getElementById('form-usuario') as HTMLFormElement | null;
    formUsuario?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const resultado = document.getElementById('resultado-usuario')!;
      const corpo = await enviar(formUsuario, '/api/usuarios/criar', resultado);
      if (corpo) {
        resultado.innerHTML = `✓ Conta <b>@${corpo.username}</b> criada (${corpo.papel}). Senha padrão: <code>${corpo.senhaPadrao}</code> — anote e entregue!`;
        resultado.className = 'font-body text-xs leading-relaxed text-ds';
        formUsuario.reset();
      }
    });

    const formSala = document.getElementById('form-sala') as HTMLFormElement | null;
    formSala?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const resultado = document.getElementById('resultado-sala')!;
      const corpo = await enviar(formSala, '/api/salas/criar', resultado);
      if (corpo) {
        resultado.textContent = '✓ Sala criada! Recarregue a página pra vê-la nas listas.';
        resultado.className = 'font-body text-xs leading-relaxed text-ds';
        formSala.reset();
      }
    });

    // excluir aula postada pelo site
    document.querySelectorAll<HTMLButtonElement>('[data-excluir]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = btn.dataset.excluir!;
        if (!confirm(`Excluir a aula "${slug}"? As questões e atividades dela vão junto.`)) return;
        const resultado = document.getElementById('resultado-aulas')!;
        resultado.textContent = 'Excluindo…';
        try {
          const resp = await fetch('/api/aulas/excluir', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug }),
          });
          const corpo = await resp.json();
          if (!resp.ok) throw new Error(corpo.error ?? 'Falha');
          btn.closest('li')?.remove();
          resultado.textContent = '✓ Aula excluída.';
          resultado.className = 'font-body text-xs mt-2 text-ds';
        } catch (err) {
          resultado.textContent = '✕ ' + (err instanceof Error ? err.message : 'Erro');
          resultado.className = 'font-body text-xs mt-2 text-enem';
        }
      });
    });

    // redefinir senha (suporte)
    document.querySelectorAll<HTMLButtonElement>('[data-redefinir]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const username = btn.dataset.redefinir!;
        if (!confirm(`Redefinir a senha de @${username}? A pessoa volta pra senha padrão e troca no próximo login.`)) return;
        const resultado = document.getElementById('resultado-senha')!;
        resultado.textContent = 'Redefinindo…';
        resultado.className = 'font-body text-xs mt-2 text-ink-soft';
        try {
          const resp = await fetch('/api/usuarios/redefinir-senha', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username }),
          });
          const corpo = await resp.json();
          if (!resp.ok) throw new Error(corpo.error ?? 'Falha');
          resultado.innerHTML = `✓ Senha de <b>@${corpo.username}</b> redefinida. Nova senha padrão: <code>${corpo.senhaPadrao}</code> — anote e entregue!`;
          resultado.className = 'font-body text-xs mt-2 text-ds';
        } catch (err) {
          resultado.textContent = '✕ ' + (err instanceof Error ? err.message : 'Erro');
          resultado.className = 'font-body text-xs mt-2 text-enem';
        }
      });
    });

    // ações de conta (só ADM): trocar papel, renomear, excluir
    async function acaoConta(url: string, body: object, sucesso: string) {
      const resultado = document.getElementById('resultado-senha')!;
      resultado.textContent = 'Aplicando…';
      resultado.className = 'font-body text-xs mt-2 text-ink-soft';
      try {
        const resp = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const corpo = await resp.json();
        if (!resp.ok) throw new Error(corpo.error ?? 'Falha');
        resultado.textContent = '✓ ' + sucesso;
        resultado.className = 'font-body text-xs mt-2 text-ds';
        setTimeout(() => location.reload(), 900);
      } catch (err) {
        resultado.textContent = '✕ ' + (err instanceof Error ? err.message : 'Erro');
        resultado.className = 'font-body text-xs mt-2 text-enem';
      }
    }

    document.querySelectorAll<HTMLButtonElement>('[data-papel]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const username = btn.dataset.papel!;
        const atual = btn.dataset.papelAtual!;
        const papel = prompt(
          `Novo papel de @${username} (atual: ${atual}).\nDigite: aluno, professor, coordenador ou adm`,
          atual
        )?.trim().toLowerCase();
        if (!papel || papel === atual) return;
        if (!['aluno', 'professor', 'coordenador', 'adm'].includes(papel)) {
          alert('Papel inválido. Use: aluno, professor, coordenador ou adm.');
          return;
        }
        acaoConta('/api/usuarios/papel', { username, papel }, `@${username} agora é ${papel}.`);
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-renomear]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const username = btn.dataset.renomear!;
        const novo = prompt(`Novo username para @${username}:`, username)?.trim().toLowerCase();
        if (!novo || novo === username) return;
        acaoConta(
          '/api/usuarios/renomear',
          { username, novoUsername: novo },
          `@${username} renomeado para @${novo}. Avise a pessoa: o login agora é o nome novo.`
        );
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-excluir-usuario]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const username = btn.dataset.excluirUsuario!;
        if (
          !confirm(
            `EXCLUIR a conta @${username}?\n\nIsso apaga a conta, os comentários e o histórico de quiz da pessoa. Não tem volta.`
          )
        )
          return;
        acaoConta('/api/usuarios/excluir', { username }, `Conta @${username} excluída.`);
      });
    });
  </script>
</Base>
