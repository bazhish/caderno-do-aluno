---
interface Props {
  title: string;
}
const { title } = Astro.props;
const id = `help-${title
  .normalize('NFD')
  .replace(/[̀-ͯ]/g, '')
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '')}`;
---

<button type="button" class="help-btn" data-help-target={id} aria-label={`Ajuda: ${title}`}>
  ?
</button>

<dialog id={id} class="help-dialog">
  <button type="button" class="help-close" data-help-close aria-label="Fechar ajuda">×</button>
  <h3 class="font-display text-lg font-bold text-ink mb-2">{title}</h3>
  <div class="font-body text-sm text-ink-soft leading-relaxed">
    <slot />
  </div>
</dialog>

<style>
  .help-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    border-radius: 9999px;
    border: 1px solid var(--color-line);
    background: var(--color-paper);
    color: var(--color-ink-soft);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .help-btn:hover {
    background: var(--color-ink);
    color: var(--color-paper);
    border-color: var(--color-ink);
  }
  .help-dialog {
    position: relative;
    border: none;
    border-radius: 0.75rem;
    padding: 1.5rem;
    max-width: 26rem;
    width: calc(100% - 2.5rem);
    background: var(--color-paper);
    color: var(--color-ink);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
  }
  .help-dialog::backdrop {
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
    backdrop-filter: blur(4px);
  }
  .help-close {
    position: absolute;
    top: 0.6rem;
    right: 0.75rem;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    border: none;
    background: transparent;
    color: var(--color-ink-soft);
    font-size: 1.1rem;
    line-height: 1;
  }
  .help-close:hover {
    color: var(--color-ink);
  }
</style>
