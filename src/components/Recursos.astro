---
interface Props {
  resources?: {
    videoAula?: { link: string; duracao?: string; motivo?: string };
    cursoGratuito?: { link: string; cargaHoraria?: string; indicadoPara?: string };
    materiaisAdicionais?: {
      ebook?: string;
      exercicios?: string;
      provaAntiga?: string;
      outro?: string;
      nivel?: string;
    };
    conteudoComplementar?: { conteudo: string; comoAjuda?: string };
  };
  accent: 'enem' | 'escolar' | 'ds';
}
const { resources, accent } = Astro.props;

const va = resources?.videoAula;
const cg = resources?.cursoGratuito;
const ma = resources?.materiaisAdicionais;
const cc = resources?.conteudoComplementar;
const hasMateriais = ma && (ma.ebook || ma.exercicios || ma.provaAntiga || ma.outro);
const hasAny = va || cg || hasMateriais || cc;
---

{hasAny && (
  <section
    class="not-prose my-10 border-t-2 border-line pt-8"
    style={`--res-accent: var(--color-${accent}); --res-soft: var(--color-${accent}-soft);`}
  >
    <h3 class="font-display text-xl md:text-2xl font-bold text-ink mb-1">Para ir além</h3>
    <p class="font-body text-sm text-ink-soft mb-6">
      Material extra escolhido a dedo pra fixar este tema — vale o clique.
    </p>

    <div class="grid sm:grid-cols-2 gap-4">
      {va && (
        <a class="res-card" href={va.link} target="_blank" rel="noopener noreferrer">
          <span class="res-icon" aria-hidden="true">🎥</span>
          <span class="res-body">
            <span class="res-kicker">Vídeo aula{va.duracao ? ` · ${va.duracao}` : ''}</span>
            <span class="res-title">{va.motivo ?? 'Veja este tema explicado em vídeo'}</span>
            <span class="res-cta">Assistir agora <span class="res-arrow">→</span></span>
          </span>
        </a>
      )}

      {cg && (
        <a class="res-card" href={cg.link} target="_blank" rel="noopener noreferrer">
          <span class="res-icon" aria-hidden="true">📚</span>
          <span class="res-body">
            <span class="res-kicker">
              Curso gratuito{cg.cargaHoraria ? ` · ${cg.cargaHoraria}` : ''}
            </span>
            <span class="res-title">
              {cg.indicadoPara
                ? `Curso completo, indicado para ${cg.indicadoPara}`
                : 'Curso completo pra dominar o assunto de vez'}
            </span>
            <span class="res-cta">Começar o curso <span class="res-arrow">→</span></span>
          </span>
        </a>
      )}

      {hasMateriais && (
        <div class="res-card">
          <span class="res-icon" aria-hidden="true">📦</span>
          <span class="res-body">
            <span class="res-kicker">
              Materiais adicionais{ma?.nivel ? ` · nível ${ma.nivel}` : ''}
            </span>
            <span class="res-rows">
              {ma?.ebook && <span class="res-row">📘 <b>Ebook/livros:</b> {ma.ebook}</span>}
              {ma?.exercicios && <span class="res-row">✏️ <b>Exercícios:</b> {ma.exercicios}</span>}
              {ma?.provaAntiga && <span class="res-row">📄 <b>Prova antiga:</b> {ma.provaAntiga}</span>}
              {ma?.outro && <span class="res-row">➕ <b>Outro:</b> {ma.outro}</span>}
            </span>
          </span>
        </div>
      )}

      {cc && (
        <div class="res-card">
          <span class="res-icon" aria-hidden="true">🔗</span>
          <span class="res-body">
            <span class="res-kicker">Conteúdo complementar</span>
            <span class="res-title"><b>{cc.conteudo}</b></span>
            {cc.comoAjuda && <span class="res-note">{cc.comoAjuda}</span>}
          </span>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .res-card {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.65);
    border: 2px solid var(--color-paper-dark);
    border-radius: 0.6rem;
    padding: 1rem 1.1rem;
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }
  a.res-card:hover {
    transform: translateY(-3px);
    border-color: var(--res-accent);
    box-shadow: 0 8px 18px rgba(31, 42, 68, 0.12);
  }
  .res-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.55rem;
    background: var(--res-soft);
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .res-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .res-kicker {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--res-accent);
    margin-bottom: 0.3rem;
  }
  .res-title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.45;
    margin-bottom: 0.5rem;
    overflow-wrap: break-word;
  }
  .res-note {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
  .res-cta {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--res-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: auto;
  }
  .res-arrow {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  a.res-card:hover .res-arrow {
    transform: translateX(4px);
  }
  .res-rows {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .res-row {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-ink);
    line-height: 1.45;
    overflow-wrap: break-word;
  }
  .res-row b {
    font-weight: 600;
  }
  @media (prefers-reduced-motion: reduce) {
    .res-card, .res-arrow { transition: none; }
  }
</style>
