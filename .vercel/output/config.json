{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/trocar-senha/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/salas/criar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/usuarios/criar/?$",
			"dest": "_render"
		},
		{
			"src": "^/ds/([^/]+?)/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/ds/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/ds/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/ds/?$",
			"dest": "_render"
		},
		{
			"src": "^/enem/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/enem/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/enem/?$",
			"dest": "_render"
		},
		{
			"src": "^/escolar/([^/]+?)/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/escolar/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/escolar/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/escolar/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/trocar-senha/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}